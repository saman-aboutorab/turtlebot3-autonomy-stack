<?xml version="1.0"?>
<!--
  TurtleBot3 Burger — Robot Description (URDF/Xacro)
  =====================================================
  This file tells ROS2 the PHYSICAL LAYOUT of the robot:
  where every sensor and joint sits in 3D space relative to the robot center.

  The robot_state_publisher node (C++) reads this file and publishes
  STATIC TF2 transforms for every <joint> defined here. Those transforms
  are what let Nav2, SLAM, and RViz2 know "the LiDAR is at THIS position
  relative to the robot body".

  COORDINATE CONVENTION (ROS standard — right-hand rule):
    x = forward
    y = left
    z = up

  FRAME HIERARCHY we are building:
    base_footprint          ← point on the floor directly under the robot
      └── base_link         ← center of the robot body (10mm above floor)
            ├── wheel_left_link
            ├── wheel_right_link
            ├── caster_back_link
            ├── imu_link    ← IMU chip inside OpenCR
            └── base_scan   ← RPLiDAR A1 scan origin

  All measurements below are from official Robotis TurtleBot3 Burger specs.
  Reference: https://emanual.robotis.com/docs/en/platform/turtlebot3/specifications/
-->
<robot name="turtlebot3_burger" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================================
       MATERIAL DEFINITIONS
       These are visual-only — used by RViz2 for color rendering.
       They have no effect on navigation or SLAM.
  ================================================================ -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.4 0.0 1.0"/>
  </material>

  <!-- ================================================================
       PROPERTIES (Xacro constants)
       Define robot geometry once here; reference them by name below.
       Changing a wheel radius here automatically updates all joints.
  ================================================================ -->
  <xacro:property name="wheel_radius"     value="0.033"/>   <!-- metres -->
  <xacro:property name="wheel_width"      value="0.018"/>   <!-- metres -->
  <xacro:property name="wheel_separation" value="0.160"/>   <!-- centre-to-centre, metres -->
  <xacro:property name="base_height"      value="0.010"/>   <!-- floor to base_link z, metres -->

  <!-- ================================================================
       LINK: base_footprint
       ================================================================
       A virtual (massless, invisible) frame. It sits on the floor plane
       directly below the robot centre.

       WHY IT EXISTS:
       Nav2 and SLAM work in the 2D floor plane. They need a frame that
       is ALWAYS at z=0 (floor level), regardless of robot tilt. That is
       base_footprint. The real robot body (base_link) is 10mm above it.
  ================================================================ -->
  <link name="base_footprint"/>

  <!-- ================================================================
       JOINT: base_footprint → base_link
       ================================================================
       TYPE: fixed  (no movement between these two frames)
       TRANSLATION: z = +0.010m (base_link sits 10mm above the floor)
  ================================================================ -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0.0 0.0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       LINK: base_link
       ================================================================
       The physical robot body centre. This is the reference frame for
       all sensors and joints. When Nav2 says "the robot is at (x, y, θ)"
       it means base_link is at that pose in the map.
  ================================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="-0.032 0.0 0.070" rpy="0 0 0"/>
      <geometry>
        <!-- Approximate box representation of the Burger chassis -->
        <box size="0.140 0.140 0.140"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="-0.032 0.0 0.070" rpy="0 0 0"/>
      <geometry>
        <box size="0.140 0.140 0.140"/>
      </geometry>
    </collision>
    <!-- inertial block required for Gazebo — mass/inertia of Burger chassis -->
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <mass value="0.829"/>
      <inertia ixx="0.00218"  ixy="0.0"  ixz="-0.000428"
               iyy="0.00218"  iyz="0.0"
               izz="0.00218"/>
    </inertial>
  </link>

  <!-- ================================================================
       WHEEL: LEFT
       ================================================================
       JOINT TYPE: continuous (spins freely, no limit)
       POSITION: x=0.0 (midpoint), y=+0.080 (left side), z=-0.023 (below base_link)
       AXIS: y-axis rotation (wheel spins around its axle)

       HOW ODOMETRY USES THIS:
       The odometry_publisher node reads encoder ticks for this joint
       from /joint_states. It uses wheel_radius and wheel_separation
       (defined above) to compute how far the robot moved.
  ================================================================ -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_left_link"/>
    <origin xyz="0.0 ${wheel_separation / 2.0} -0.023" rpy="-1.5707963 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.029"/>
      <inertia ixx="1.117e-5" ixy="0.0" ixz="0.0"
               iyy="1.117e-5" iyz="0.0"
               izz="1.576e-5"/>
    </inertial>
  </link>

  <!-- ================================================================
       WHEEL: RIGHT
  ================================================================ -->
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_right_link"/>
    <origin xyz="0.0 -${wheel_separation / 2.0} -0.023" rpy="-1.5707963 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.029"/>
      <inertia ixx="1.117e-5" ixy="0.0" ixz="0.0"
               iyy="1.117e-5" iyz="0.0"
               izz="1.576e-5"/>
    </inertial>
  </link>

  <!-- ================================================================
       CASTER (rear ball wheel)
       ================================================================
       The Burger has a small ball caster at the back for balance.
       It's a fixed joint (no encoder) — odometry ignores it.
  ================================================================ -->
  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_back_link"/>
    <origin xyz="-0.177 0.0 -0.0035" rpy="-1.5707963 0 0"/>
  </joint>

  <link name="caster_back_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="2e-6" ixy="0.0" ixz="0.0"
               iyy="2e-6" iyz="0.0"
               izz="2e-6"/>
    </inertial>
  </link>

  <!-- ================================================================
       IMU LINK — MPU-9250 inside OpenCR
       ================================================================
       JOINT TYPE: fixed (bolted to robot body, never moves)
       POSITION: x=-0.032, y=0.0, z=0.068

       WHY THIS MATTERS:
       When the EKF receives IMU data, it needs to know the IMU's
       orientation relative to base_link to correctly transform
       angular velocity and linear acceleration into the robot frame.

       For the Burger, the OpenCR is mounted with the same orientation
       as base_link, so rpy="0 0 0" — no rotation needed.
  ================================================================ -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="-0.032 0.0 0.068" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>

  <!-- ================================================================
       BASE_SCAN — RPLiDAR A1M8 scan origin
       ================================================================
       JOINT TYPE: fixed (LiDAR is mounted rigidly on top of the robot)
       POSITION:
         x = -0.032m  (slightly behind robot centre — matching the bracket)
         y =  0.0     (centred left-right)
         z =  0.172m  (on top of the Burger tower, ~17cm above base_link)

       WHY THIS MATTERS (CRITICAL):
       The RPLiDAR reports distances as if it were at the ORIGIN of its
       own frame. When SLAM Toolbox receives /scan, it uses the TF from
       base_footprint → base_scan to know where in the map those laser
       points actually are. If this offset is wrong by even a few cm,
       your SLAM map will look warped or double-walled.

       The frame is called "base_scan" to match the default expected by
       the TurtleBot3 bringup and SLAM Toolbox config.
  ================================================================ -->
  <joint name="scan_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="base_scan"/>
    <origin xyz="-0.032 0.0 0.172" rpy="0 0 3.14159"/>
  </joint>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0508" length="0.055"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0508" length="0.055"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.114"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

</robot>
